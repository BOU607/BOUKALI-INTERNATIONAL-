# Stripe (card payments - amount deducted automatically from customer)
# Sign up at https://stripe.com
STRIPE_SECRET_KEY=sk_test_...
# Optional platform fees (percent). Defaults: buyer 1, seller 1.5
# BUYER_FEE_PERCENT=1
# SELLER_FEE_PERCENT=1.5
# Optional Stripe Connect default seller country for onboarding links (e.g. FR, QA, AU)
# STRIPE_CONNECT_COUNTRY=FR
# Phase 1 ledger database (Prisma/PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/miahamarket

# Optional: for redirect URLs if different from request origin
# NEXT_PUBLIC_APP_URL=https://www.miahamarket.com

# Bank transfer – choose ONE: International (IBAN/SWIFT) OR local bank fields.
# International format:
NEXT_PUBLIC_BANK_NAME=Your Bank Name
NEXT_PUBLIC_ACCOUNT_HOLDER=Your Full Name
NEXT_PUBLIC_IBAN=QA58DOHB00001234567890
NEXT_PUBLIC_SWIFT=DOHBQAQA
# Optional local bank format (only if NOT using IBAN):
# NEXT_PUBLIC_BSB=
# NEXT_PUBLIC_ACCOUNT=
# Required for Admin login – add these in Vercel → Settings → Environment Variables
NEXTAUTH_SECRET=your-random-secret-at-least-32-chars
# Must match the URL you use in the browser. Local: http://localhost:3000 or http://localhost:3001
# Production: use your canonical domain (www.miahamarket.com)
NEXTAUTH_URL=https://www.miahamarket.com
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-password

# Seller notifications – email sellers when buyer places order (Resend)
# Sign up at https://resend.com, get API key, verify your domain
# RESEND_API_KEY=re_...
# NOTIFY_FROM_EMAIL=Miaha Market <orders@yourdomain.com>

# Optional: Vercel KV – required for sellers, orders, products in production.
# Without KV, local dev still works: you can log in as seller with:
#   Email: seller@test.com   Password: seller123
# To enable this test seller in production (when KV is empty or not configured):
# ALLOW_DEV_SELLER=true
# Create a KV store in Vercel → Storage → KV, then link to project to get these.
# KV_REST_API_URL=https://xxx.upstash.io
# KV_REST_API_TOKEN=...

# Optional: contact info (footer & /contact). Phone/WhatsApp: international format e.g. +1234567890
# NEXT_PUBLIC_CONTACT_PHONE=+1234567890
# NEXT_PUBLIC_CONTACT_WHATSAPP=+1234567890
# NEXT_PUBLIC_CONTACT_ADDRESS=Your business address
# NEXT_PUBLIC_GOOGLE_MAP_LINK=https://www.google.com/maps/place/...
# NEXT_PUBLIC_GOOGLE_MAP_EMBED_SRC=https://www.google.com/maps/embed?pb=...
