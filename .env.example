# Stripe (card payments - amount deducted automatically from customer)
# Sign up at https://stripe.com (e.g. Stripe Turkey for Turkish account)
STRIPE_SECRET_KEY=sk_test_...

# Optional: for redirect URLs if different from request origin
# NEXT_PUBLIC_APP_URL=https://boukali-international.vercel.app

# Bank transfer – choose ONE: Australian (BSB) OR International (IBAN)
# Turkish bank (IBAN) – set these and leave BSB/ACCOUNT empty:
NEXT_PUBLIC_BANK_NAME=Your Turkish Bank Name
NEXT_PUBLIC_ACCOUNT_HOLDER=Your Full Name
NEXT_PUBLIC_IBAN=TR00 0000 0000 0000 0000 0000 00
NEXT_PUBLIC_SWIFT=XXXXXXXX
# Australian format (only if NOT using IBAN – remove BSB/ACCOUNT if using Turkish):
# NEXT_PUBLIC_BSB=
# NEXT_PUBLIC_ACCOUNT=
# Required for Admin login – add these in Vercel → Settings → Environment Variables
NEXTAUTH_SECRET=your-random-secret-at-least-32-chars
# Production: use your Vercel URL (e.g. https://boukali-international-jgjp.vercel.app)
NEXTAUTH_URL=https://your-project.vercel.app
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-password

# Optional: Vercel KV – required for "Visitors" to persist on Vercel (file storage is read-only there)
# Create a KV store in Vercel → Storage → KV, then link to project to get these.
# KV_REST_API_URL=https://xxx.upstash.io
# KV_REST_API_TOKEN=...

# Optional: contact info (footer & /contact). Phone/WhatsApp: international format e.g. +1234567890
# NEXT_PUBLIC_CONTACT_PHONE=+1234567890
# NEXT_PUBLIC_CONTACT_WHATSAPP=+1234567890
# NEXT_PUBLIC_CONTACT_ADDRESS=Your business address
# NEXT_PUBLIC_GOOGLE_MAP_LINK=https://www.google.com/maps/place/...
# NEXT_PUBLIC_GOOGLE_MAP_EMBED_SRC=https://www.google.com/maps/embed?pb=...
